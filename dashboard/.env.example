# =============================================================================
# Supabase keys
# Supabase renamed its API keys in late 2024:
#   anon key         → publishable key  (still public, safe to bundle)
#   service_role key → secret key       (still server-only)
# Either spelling is accepted by lib/env.ts. Use whatever the Supabase
# dashboard shows you under Settings → API Keys.
# =============================================================================

# Supabase — public values, safe to bundle (pick ONE name; new is preferred)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-publishable-key
# Legacy fallback (still works if your project still shows it):
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ-your-public-anon-key

# Supabase — SERVER ONLY, NEVER bundle to client (pick ONE name)
SUPABASE_SECRET_KEY=sb_secret_your-secret-key
# Legacy fallback (still works if your project still shows it):
# SUPABASE_SERVICE_ROLE_KEY=eyJ-your-service-role-key

# OpenRouter — SERVER ONLY
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key

# Session JWT secret — SERVER ONLY (generate with: openssl rand -hex 32)
AUTH_SESSION_SECRET=your-32-byte-hex-secret
