# =============================================================================
# Supabase keys
# Supabase renamed its API keys in late 2024:
#   anon key         → publishable key  (still public, safe to bundle)
#   service_role key → secret key       (still server-only)
# Either spelling is accepted by lib/env.ts. Use whatever the Supabase
# dashboard shows you under Settings → API Keys.
# =============================================================================

# Supabase — public values, safe to bundle (pick ONE name; new is preferred)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-publishable-key
# Legacy fallback (still works if your project still shows it):
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ-your-public-anon-key

# Supabase — SERVER ONLY, NEVER bundle to client (pick ONE name)
SUPABASE_SECRET_KEY=sb_secret_your-secret-key
# Legacy fallback (still works if your project still shows it):
# SUPABASE_SERVICE_ROLE_KEY=eyJ-your-service-role-key

# OpenRouter — SERVER ONLY
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key

# Session JWT secret — SERVER ONLY (generate with: openssl rand -hex 32)
AUTH_SESSION_SECRET=your-32-byte-hex-secret

# =============================================================================
# Brain / memory (the "gbrain layer")
# =============================================================================
# BMO's memory runs on Supabase pgvector + OpenRouter embeddings by default —
# no extra config needed. Just apply supabase/migrations/0003_brain_memory.sql
# and keep the "memory" skill enabled in the dashboard.
#
# OPTIONAL — point at a real gbrain daemon (github.com/garrytan/gbrain) running
# on a VPS once you outgrow the built-in store. When GBRAIN_HTTP_URL is set,
# lib/brain.ts routes recall + capture to the daemon's MCP endpoint instead of
# Supabase. Leave BLANK to use the built-in Supabase-backed brain.
# GBRAIN_HTTP_URL=https://your-brain.example.com
# GBRAIN_TOKEN=gbrain-bearer-token-from-`gbrain auth create`

# Dream cycle (brain consolidation) cron secret — SERVER ONLY.
# Protects POST /api/brain/dream. Vercel Cron sends this as a Bearer token.
# Generate with: openssl rand -hex 32. If unset, the dream endpoint refuses
# all calls (fails closed).
CRON_SECRET=your-32-byte-hex-secret

# =============================================================================
# BMO voice effect — "robotic radio" lo-fi treatment (lib/voice-fx.ts)
# =============================================================================
# Applied to BMO's SPOKEN voice on every TTS path: the simulator (/api/sim/tts)
# and the device (/api/brain, /api/voice/tts). Song playback is NOT affected.
# Defaults are tuned to be characterful but still intelligible for a child.
#
# Set BMO_VOICE_FX=off to disable the effect entirely (clean voice).
# BMO_VOICE_FX=on
#
# Fine-tuning (all optional; omit to use the tuned defaults). No redeploy of
# code needed — change the env value and restart/redeploy.
#   HIGHPASS/LOWPASS = the radio band (Hz). Narrower band = more "telephone".
#   DECIMATE         = sample-and-hold factor; higher = more robotic aliasing.
#   BITS             = bitcrush depth (1-16); lower = grittier/more digital.
#   DRIVE            = saturation/rasp (>=1).
#   GAIN             = output makeup gain.
#   MIX              = dry/wet blend 0..1 (1 = full effect, lower = cleaner).
# BMO_VOICE_FX_HIGHPASS=520
# BMO_VOICE_FX_LOWPASS=3600
# BMO_VOICE_FX_DECIMATE=2
# BMO_VOICE_FX_BITS=10
# BMO_VOICE_FX_DRIVE=1.6
# BMO_VOICE_FX_GAIN=1.05
# BMO_VOICE_FX_MIX=0.85
