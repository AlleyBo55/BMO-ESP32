#pragma once

// Template for include/secrets.h. You normally don't touch this or secrets.h
// directly: the pre-build hook (scripts/check_secrets_h.py) renders
// include/secrets.h by substituting each placeholder marker below with the
// matching value from the gitignored .env file. Edit .env (see .env.example)
// instead of editing this template or secrets.h directly.
//
// Generate the fingerprint via the BMO Dashboard onboarding wizard or rotate
// page, paste it into .env as FINGERPRINT=..., then re-flash the firmware.

#define BMO_WIFI_SSID     "@WIFI_SSID@"
#define BMO_WIFI_PASS     "@WIFI_PASS@"

// Optional fallback network — tried automatically when the primary fails.
// Leave the placeholder values (or both empty) to disable the fallback.
#define BMO_WIFI_SSID2    "@WIFI_SSID2@"
#define BMO_WIFI_PASS2    "@WIFI_PASS2@"

#define BMO_DASHBOARD_URL "@DASHBOARD_URL@"
#define BMO_FINGERPRINT   "@FINGERPRINT@"
