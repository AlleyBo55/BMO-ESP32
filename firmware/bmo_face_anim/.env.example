# BMO firmware secrets template. Copy to .env and fill in real values:
#   cp .env.example .env
#
# The pre-build hook (scripts/check_secrets_h.py) reads .env and renders
# include/secrets.h from include/secrets.h.in by substituting each @KEY@
# with the matching VALUE below. .env is gitignored — never commit it.

# Primary 2.4 GHz WiFi
WIFI_SSID=your-home-wifi
WIFI_PASS=your-wifi-password

# Fallback network — tried automatically when the primary fails to associate
# or drops out. Leave both empty to disable the fallback.
WIFI_SSID2=
WIFI_PASS2=

# Deployed dashboard origin (no trailing slash)
DASHBOARD_URL=https://your-bmo-dashboard.vercel.app

# Dashboard-issued device fingerprint (from onboarding/rotate UI)
FINGERPRINT=your-fingerprint-from-dashboard
